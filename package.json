{
  "name": "jif",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "workspaces": [
    "packages/*",
    "ext/*"
  ],
  "scripts": {
    "clean": "rm -rf dist .tmp",
    "test": "bun test",
    "typecheck": "bunx tsc --noEmit",
    "typecheck:workspaces": "bun run --filter '*' typecheck",
    "build": "bun run scripts/build.ts",
    "start": "bun run index.ts",
    "sample": "bun run index.ts --sample",
    "dev": "bun --watch ./index.ts --sample",
    "bin": "bun run scripts/install-binary.ts",
    "live": "bun run bin && jif",
    "vsc:local": "bun run --cwd ext/vscode install:local"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "@types/node": "^25.6.0"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@opentui/core": "^0.1.90",
    "@opentui/solid": "^0.1.90",
    "fzy.js": "^0.4.1",
    "solid-js": "^1.9.11"
  }
}
