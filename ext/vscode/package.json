{
  "name": "jif-vscode",
  "displayName": "Jif",
  "description": "Minimal VS Code integration for Jujutsu using JIF primitives",
  "version": "0.0.0",
  "private": true,
  "publisher": "local",
  "type": "module",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "SCM Providers"
  ],
  "extensionKind": [
    "workspace"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "scripts": {
    "build": "node ./scripts/ensure-node-pty-helper.mjs && bun build ./src/extension.ts --outdir ./dist --target=node --external vscode --external node-pty",
    "build:jif-binary": "bun run ./scripts/build-jif-binary.ts",
    "build:package-assets": "bun run build && bun run build:jif-binary",
    "install:local": "bun run build:package-assets && bun run ./scripts/install-local.ts",
    "vscode:prepublish": "bun run build:package-assets",
    "package:vsix": "npm exec --yes @vscode/vsce -- package",
    "typecheck": "bunx tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@jif/jj-core": "workspace:*",
    "@xterm/addon-fit": "^0.11.0",
    "node-pty": "^1.1.0",
    "xterm": "^5.3.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/vscode": "^1.110.0"
  },
  "contributes": {
    "views": {
      "scm": [
        {
          "type": "webview",
          "id": "jifGraph",
          "name": "Graph",
          "visibility": "visible",
          "when": "jif.repoActive"
        },
        {
          "id": "jifOperationLog",
          "name": "Operation Log",
          "when": "jif.repoActive"
        }
      ]
    },
    "commands": [
      {
        "command": "jif.refresh",
        "title": "Refresh",
        "category": "Jif",
        "icon": "$(refresh)"
      },
      {
        "command": "jif.openAllChanges",
        "title": "Open Changes",
        "category": "Jif",
          "icon": "$(diff-multiple)"
      },
      {
        "command": "jif.refreshOperationLog",
        "title": "Refresh Operation Log",
        "category": "Jif",
        "icon": "$(refresh)"
      },
      {
        "command": "jif.refreshGraph",
        "title": "Refresh Graph",
        "category": "Jif",
        "icon": "$(refresh)"
      },
      {
        "command": "jif.focusGraph",
        "title": "Focus Graph",
        "category": "Jif"
      }
    ],
    "keybindings": [
      {
        "command": "jif.focusGraph",
        "key": "ctrl+alt+j",
          "mac": "cmd+ctrl+j",
        "when": "jif.repoActive"
      }
    ],
    "menus": {
      "scm/title": [
        {
          "command": "jif.refresh",
          "when": "scmProvider == jif",
          "group": "navigation"
        }
      ],
      "scm/resourceGroup/context": [
        {
          "command": "jif.openAllChanges",
          "when": "scmProvider == jif && scmResourceGroup == working-copy",
          "group": "inline"
        }
      ],
      "view/title": [
        {
          "command": "jif.refreshOperationLog",
          "when": "view == jifOperationLog",
          "group": "navigation@1"
        },
        {
          "command": "jif.refreshGraph",
          "when": "view == jifGraph",
          "group": "navigation@1"
        }
      ]
    }
  }
}